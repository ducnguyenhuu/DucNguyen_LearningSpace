# ─────────────────────────────────────────────
# Local Knowledge Base — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Knowledge Base
# Path to the folder containing your documents (Word, Markdown, PDF)
KNOWLEDGE_FOLDER=/path/to/your/documents

# Server Binding (FR-020)
# Default: localhost only — prevents unintended LAN exposure
HOST=127.0.0.1
# HOST=0.0.0.0  # Uncomment to allow LAN or server access
PORT=8000

# ── Embedding ──────────────────────────────────
EMBEDDING_PROVIDER=sentence-transformers
EMBEDDING_MODEL=nomic-embed-text-v1.5
EMBEDDING_DIMENSIONS=768

# ── LLM ────────────────────────────────────────
LLM_PROVIDER=ollama
LLM_MODEL=phi3.5:3.8b-mini-instruct-q4_K_M
LLM_BASE_URL=http://localhost:11434
LLM_CONTEXT_WINDOW=4096
LLM_TEMPERATURE=0.1

# ── Retrieval ──────────────────────────────────
# top_k: max number of chunks to retrieve per query
RETRIEVAL_TOP_K=5
# Chunks with similarity score below this threshold are excluded (FR-008)
RETRIEVAL_SIMILARITY_THRESHOLD=0.7

# ── Chunking ───────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ── Conversation ───────────────────────────────
# Number of most recent messages to include in LLM context window (FR-011)
SLIDING_WINDOW_MESSAGES=10

# ── Database ───────────────────────────────────
# SQLite (local development)
DATABASE_URL=sqlite+aiosqlite:///./data/knowledge_base.db
# PostgreSQL (server deployment — uncomment and fill in)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/knowledge_base

# ── ChromaDB ───────────────────────────────────
CHROMA_PERSIST_DIR=./data/chromadb
CHROMA_COLLECTION_NAME=knowledge_base

# ── Logging ────────────────────────────────────
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR
