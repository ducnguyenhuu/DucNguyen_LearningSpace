{
  "name": "1shot-e2e-coding-agent",
  "version": "0.1.0",
  "description": "One-shot end-to-end coding agent powered by Pi SDK",
  "type": "module",
  "bin": {
    "1shot-agent": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "0.57.1",
    "@octokit/rest": "^20.1.0",
    "@xenova/transformers": "^2.17.2",
    "commander": "^12.1.0",
    "js-tiktoken": "^1.0.15",
    "pino": "^9.2.0",
    "simple-git": "^3.24.0",
    "vectra": "^0.9.0",
    "web-tree-sitter": "^0.22.6"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@vitest/coverage-v8": "^2.0.5",
    "pino-pretty": "^11.2.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
